# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/audio_core"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# HTTP server
PORT=3000

# WebSocket gateway (separate port)
WS_PORT=3001

# Proxy targets
PROXY_WS_TARGET="ws://localhost:8080"
PROXY_REST_TARGET="http://localhost:8080"
PROXY_REST_PATH="/audio"
