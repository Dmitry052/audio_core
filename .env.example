# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/audio_core"

# Connection pool — DB_POOL_MAX * CLUSTER_WORKERS must stay below PostgreSQL max_connections (default 100)
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=3000

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# HTTP server
PORT=3000

# WebSocket gateway (separate port)
WS_PORT=3001

# Proxy targets
PROXY_WS_TARGET="ws://localhost:8080"
PROXY_REST_TARGET="http://localhost:8080"
PROXY_REST_PATH="/audio"

# Clustering — number of worker processes (default: 1 = no clustering)
# In production set to $(nproc) or number of CPU cores
# Rule: DB_POOL_MAX * CLUSTER_WORKERS < postgres max_connections
CLUSTER_WORKERS=1
